{
  "$schema": "./tsconfig-schema.json",
  "extends": "astro/tsconfigs/strict",
  "include": ["**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "rootDirs": [".", "cmk"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*", "./cmk/src/*"]
    }
  },
  "cmkOptions": {
    "enabled": true,
    "dtsOutDir": "cmk"
  }
}
